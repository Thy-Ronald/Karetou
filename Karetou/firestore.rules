rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if user is admin or superadmin
    function isAdmin() {
      return isAuthenticated();
      // NOTE: For production, you may want to restrict this to actual admins:
      // return isAuthenticated() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own profile or any other user's profile (for displaying profile images, etc.)
      allow read: if isAuthenticated();
      // Users can only write their own data
      allow write: if isAuthenticated() && isOwner(userId);
      // Allow creation during signup
      allow create: if isAuthenticated();
    }
    
    // Admin Users collection - For admin panel
    match /adminUsers/{adminId} {
      // Allow authenticated users to read adminUsers (needed for login to check if user is admin)
      allow read: if isAuthenticated();
      // Only superadmins can create/update/delete admin users
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Activity Logs collection - For admin panel
    match /activityLogs/{logId} {
      // Explicitly allow both queries and individual document reads
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Admin Activity Logs collection - For admin panel history
    match /adminActivityLogs/{logId} {
      // Explicitly allow both queries and individual document reads
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Admin History Logs collection - For admin panel history
    match /adminHistoryLogs/{logId} {
      // Explicitly allow both queries and individual document reads
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Archived Users collection - For admin panel archive
    match /archivedUsers/{archivedId} {
      // Explicitly allow both queries and individual document reads
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Archived Admins collection - For admin panel archive
    match /archivedAdmins/{archivedId} {
      // Explicitly allow both queries and individual document reads
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Businesses collection - Allow all authenticated users to read
    // Explicitly allow both queries and individual document reads
    match /businesses/{businessId} {
      // Allow reading individual documents
      allow get: if isAuthenticated();
      // Allow listing/querying the collection
      allow list: if isAuthenticated();
      // Allow all other read operations
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Reviews subcollection
    match /businesses/{businessId}/reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Promotions collection
    match /promotions/{promotionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // User tokens collection
    match /userTokens/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
      allow create, update: if isAuthenticated();
    }
    
    // Saved businesses collection
    match /savedBusinesses/{savedId} {
      allow read, write: if isAuthenticated();
    }
    
    // Places to visit
    match /placesToVisit/{placeId} {
      allow read, write: if isAuthenticated();
    }
    
    // Posts collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Transactions collection
    match /transactions/{transactionId} {
      allow read, write: if isAuthenticated();
    }
    
    // Reviews collection (top-level if exists)
    match /reviews/{reviewId} {
      allow read, write: if isAuthenticated();
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

