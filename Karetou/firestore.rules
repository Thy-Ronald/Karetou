rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if user is admin or superadmin
    function isAdmin() {
      return isAuthenticated();
      // NOTE: For production, you may want to restrict this to actual admins:
      // return isAuthenticated() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own profile or any other user's profile (for displaying profile images, etc.)
      allow read: if isAuthenticated();
      // Users can only write their own data
      allow write: if isAuthenticated() && isOwner(userId);
      // Allow creation during signup
      allow create: if isAuthenticated();
      // Explicitly allow delete for account deletion
      allow delete: if isAuthenticated() && isOwner(userId);
    }
    
    // Admin Users collection - For admin panel
    match /adminUsers/{adminId} {
      // Allow authenticated users to read adminUsers (needed for login to check if user is admin)
      allow read: if isAuthenticated();
      // Only superadmins can create/update/delete admin users
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Activity Logs collection - For admin panel
    match /activityLogs/{logId} {
      // Explicitly allow both queries and individual document reads
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Admin Activity Logs collection - For admin panel history
    match /adminActivityLogs/{logId} {
      // Explicitly allow both queries and individual document reads
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Admin History Logs collection - For admin panel history
    match /adminHistoryLogs/{logId} {
      // Explicitly allow both queries and individual document reads
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Archived Users collection - For admin panel archive
    match /archivedUsers/{archivedId} {
      // Explicitly allow both queries and individual document reads
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Archived Admins collection - For admin panel archive
    match /archivedAdmins/{archivedId} {
      // Explicitly allow both queries and individual document reads
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Businesses collection - Allow all authenticated users to read
    // Explicitly allow both queries and individual document reads
    match /businesses/{businessId} {
      // Allow reading individual documents
      allow get: if isAuthenticated();
      // Allow listing/querying the collection
      allow list: if isAuthenticated();
      // Allow all other read operations
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Reviews subcollection
    match /businesses/{businessId}/reviews/{reviewId} {
      // Allow anyone to read reviews for display; writes still require auth
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // Followers subcollection
    match /businesses/{businessId}/followers/{followerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == followerId;
      allow update: if false; // no updates, only create/delete
      allow delete: if isAuthenticated() && request.auth.uid == followerId;
    }

    // User follows mirror: users/{userId}/follows/{businessId}
    match /users/{userId}/follows/{businessId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if false;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Promotions collection
    match /promotions/{promotionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // User tokens collection
    match /userTokens/{tokenId} {
      // If document ID is userId, check ownership
      // If document has userId field, check that field
      allow read: if isAuthenticated() && (
        isOwner(tokenId) || 
        resource.data.userId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        isOwner(tokenId) || 
        request.resource.data.userId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        isOwner(tokenId) || 
        resource.data.userId == request.auth.uid
      );
      // Allow delete if user owns the token
      allow delete: if isAuthenticated() && (
        isOwner(tokenId) || 
        resource.data.userId == request.auth.uid
      );
    }
    
    // Saved businesses collection
    match /savedBusinesses/{savedId} {
      allow read: if isAuthenticated();
      // Allow write (create/update) if authenticated
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Allow delete if user owns the document
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Places to visit
    match /placesToVisit/{placeId} {
      allow read: if isAuthenticated();
      // Allow write (create/update) if authenticated
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Allow delete if user owns the document
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Posts collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Transactions collection
    match /transactions/{transactionId} {
      allow read: if isAuthenticated();
      // Allow write (create/update) if authenticated
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Allow delete if user owns the document
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // User Points collection - For reward points system
    match /userPoints/{pointsId} {
      allow read: if isAuthenticated();
      // Allow create if user owns it
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Allow update if user owns it
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Allow delete if user owns the document
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Reviews collection (top-level if exists)
    match /reviews/{reviewId} {
      allow read, write: if isAuthenticated();
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

